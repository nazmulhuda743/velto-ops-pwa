+/* ==================== REVENUE-AT-RISK ENGINE (v63) ====================
+   Turns lifecycle stage + each customer's PERSONAL cadence into a churn
+   probability and a ৳ figure, so the follow-up list can be sorted by the
+   money that is actually bleeding out today — not just the oldest stage.
+   Pure client-side: uses fields the reorder engine already computes. */
+function roRisk(c){
+  if(!c) return {p:0,atRisk:0,band:'none',over:0};
+  const gap=Number(c.gap)||0, days=(c.days==null?0:Number(c.days));
+  const cyc=gap>0?gap:(c.repeat?30:14);              // personal rhythm, sane fallback
+  const over=cyc>0?days/cyc:1;                        // 1.0 = on time, 2.0 = a full cycle late
+  let p;
+  if(over<=1) p=0.04+0.12*over;                       // still inside their cycle — low
+  else p=0.16+0.30*(over-1);                          // past due — climbs every extra cycle
+  // stage floors/ceilings (the engine already knows the lifecycle truth)
+  if(c.stage==='winback') p=Math.max(p,0.78);
+  else if(c.stage==='overdue') p=Math.max(p,0.52);
+  else if(c.stage==='lost') p=0.95;
+  else if(c.stage==='loyal'||c.stage==='thank') p=Math.min(p,0.22);
+  else if(c.stage==='inflight'||c.stage==='converted') p=0.02;
+  if(!c.repeat) p+=0.12;                              // one-and-done churn far harder than repeats
+  const h=c.history||[];                              // logged-outcome signal
+  if(h.length){
+    const txt=h.map(a=>((a.outcome||'')+' '+(a.note||'')).toLowerCase()).join(' ');
+    if(/complain|refund|damage|angry|ruined|not interested|wrong number/.test(txt)) p+=0.15;
+    const fresh=h[0]&&(Date.now()-new Date(h[0].created_at).getTime())<10*86400000;
+    if(fresh && /pickup booked|replied|coming|agreed|will|wants reminder/.test(txt)) p-=0.22;
+  }
+  p=Math.max(0.01,Math.min(0.98,p));
+  const value=Number(c.potential||c.avg||c.value)||0;
+  const atRisk=Math.round(p*value);
+  const band=p>=0.66?'high':p>=0.4?'med':'low';
+  return {p,atRisk,band,over};
+}
+function roRiskPill(c){
+  const r=c.risk||roRisk(c);
+  if(r.band==='low'||r.band==='none'||!r.atRisk) return '';
+  const col=r.band==='high'?'var(--danger,#ff5c6c)':'var(--amber,#ffb020)';
+  return `<span class="ro-risk-pill" title="Estimated revenue at risk if they don't come back" style="display:inline-flex;align-items:center;gap:4px;font-size:10.5px;font-weight:800;color:${col};border:1px solid ${col};border-radius:999px;padding:2px 8px;white-space:nowrap">🩸 ৳${r.atRisk.toLocaleString()} · ${Math.round(r.p*100)}%</span>`;
+}
