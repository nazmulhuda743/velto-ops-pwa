+        riskPct:(c&&c.risk)?Math.round(c.risk.p*100):null, variety:regen?1:0 };
+      const {data,error}=await sb.functions.invoke(AI_COPILOT_FN,{body:payload});
+      if(error) throw error;
+      if(data&&data.message){ msg=String(data.message).trim(); if(data.sendWindow) meta='📆 Suggested send time: '+data.sendWindow; }
+    }
+  }catch(e){ console.warn('ai-copilot:',e); }
+  if(!msg){
