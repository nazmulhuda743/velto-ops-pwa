From 57d1bc43076f2757535fcfe65e819933315ee5ac Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Thu, 16 Jul 2026 21:58:52 +0000
Subject: [PATCH 1/2] Fix invoice PDF gradients dropping out on download
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The header/balance-card glows were drawn with jsPDF GState soft transparency.
That renders in the in-app preview but drops out (or turns into solid blobs)
in the downloaded PDF on viewers that ignore ExtGState transparency — so the
gradients vanished the moment the invoice was saved.

Redraw _glow() as concentric SOLID ellipses whose colour is pre-blended from
the background toward the glow colour — the same viewer-proof technique the
gradient bar already uses. No transparency, so the glow renders identically in
every PDF viewer, including the downloaded file. Verified by generating the
real PDF with jsPDF and rendering it: header and balance-card glows match the
in-app design.
---
 index.html | 19 +++++++++++++------
 1 file changed, 13 insertions(+), 6 deletions(-)

diff --git a/index.html b/index.html
index f87ab86..d614150 100644
--- a/index.html
+++ b/index.html
@@ -2474,12 +2474,19 @@ function _gradBar(doc,x,y,w,h){
     else{const u=(t-0.5)/0.5;c=[_lerp(st[1][0],st[2][0],u),_lerp(st[1][1],st[2][1],u),_lerp(st[1][2],st[2][2],u)];}
     doc.setFillColor(c[0],c[1],c[2]);doc.rect(x+i*seg,y,seg+0.35,h,'F');}
 }
-function _glow(doc,cx,cy,r,rgb,base){
-  if(!doc.GState){return;}
-  try{doc.saveGraphicsState();
-  [[1.0,0.08],[0.74,0.13],[0.5,0.20],[0.3,0.28]].forEach(function(L){
-    doc.setGState(new doc.GState({opacity:L[1]*base}));doc.setFillColor(rgb[0],rgb[1],rgb[2]);doc.ellipse(cx,cy,r*L[0],r*L[0],'F');});
-  doc.restoreGraphicsState();}catch(e){try{doc.restoreGraphicsState();}catch(_){} }
+function _glow(doc,cx,cy,r,rgb,base,bg){
+  // Soft radial glow WITHOUT PDF transparency: concentric solid ellipses whose
+  // colour is pre-blended from the background toward the glow colour. This is
+  // the same viewer-proof technique as _gradBar — the earlier GState/opacity
+  // version rendered in the in-app preview but dropped out (or turned into solid
+  // blobs) in the downloaded PDF on viewers that ignore soft transparency.
+  bg=bg||[11,16,32];            // header + balance card are both navy
+  const N=16;
+  for(let i=0;i<N;i++){ const f=i/(N-1);
+    const rad=r*(1-0.86*f);                       // large (dim, outer) → small (bright, inner)
+    const a=Math.min(1, Math.pow(f,1.3)*base*0.95 + 0.02);
+    doc.setFillColor(_lerp(bg[0],rgb[0],a),_lerp(bg[1],rgb[1],a),_lerp(bg[2],rgb[2],a));
+    doc.ellipse(cx,cy,rad,rad,'F'); }
 }
 async function stainsForInvoice(s){
   if(!s||s.stains!==undefined||!s.dbid||!sb) return (s&&s.stains&&s.stains.length)?true:false;
-- 
2.43.0


From 3784b1180246225492a58e9c9e0ea12a4495248b Mon Sep 17 00:00:00 2001
