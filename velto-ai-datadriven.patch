+/* ---- 1. Likely-to-order-soon (the positive twin of revenue-at-risk) ---- */
+function roDue(c){
+  if(!c || c.stage==='inflight' || c.stage==='converted' || c.stage==='lost') return {soon:false,score:0,when:''};
+  const gap=Number(c.gap)||0, days=(c.days==null?null:Number(c.days));
+  if(!gap || days==null) return {soon:false,score:0,when:''};
+  const r=days/gap;                                  // 1.0 = exactly on their usual rhythm
+  let score=0;
+  if(r>=0.7 && r<=1.6) score=1-Math.abs(1-r);        // peak intent right around their cadence
+  else if(r>1.6 && r<=2.2) score=0.22;               // late but still catchable
+  if(c.repeat) score+=0.15;                          // proven repeat buyers are likelier
+  if(c.ratio!=null && c.ratio>=0.8 && c.ratio<=1.3) score+=0.15;  // consistent rhythm = predictable
+  if((Number(c.orderCount)||0)>=4) score+=0.10;      // habit formed
+  score=Math.max(0,Math.min(1,score));
+  return {soon:score>=0.55, score, when:(r<=1?'due now':'due any day')};
+}
